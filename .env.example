# ====================================================================
# Pio_lab — Environment Variables
# Copy này thành .env và điền giá trị thật
# KHÔNG commit .env lên Git
# ====================================================================

# --- Application ---
APP_NAME=Pio_lab
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# --- PostgreSQL (Memory Layer) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pio_lab
POSTGRES_USER=pio_lab
POSTGRES_PASSWORD=changeme

# --- Obsidian Vault ---
OBSIDIAN_VAULT_PATH=./vault

# --- Department worker mode ---
# deterministic = stable local workers; provider = text workers call ProviderRouter/Codex OAuth.
DEPARTMENT_WORKER_MODE=deterministic
# Optional: codex_oauth promotes selected text routing paths to Codex OAuth.
PROVIDER_ROUTING_PROFILE=

# ====================================================================
# Provider API Keys (Layer Provider Router)
# ====================================================================

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_2=

# --- OpenAI / Codex ---
OPENAI_API_KEY=
OPENAI_API_KEY_2=
# Optional: use Codex CLI ChatGPT/OAuth login instead of API key.
# Run `codex login`, then Pio_lab can use ~/.codex/auth.json for the codex_oauth account.
CODEX_HOME=
CODEX_AUTH_FILE=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY_2=

# --- Ollama (Local AI via Tailscale) ---
OLLAMA_HOST=http://100.x.x.x:11434
OLLAMA_DEFAULT_MODEL=gpt-oss-20b
TAILSCALE_AUTHKEY=

# ====================================================================
# Channel Adapters (Layer 1)
# ====================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_TEST_CHAT_ID=

# --- Discord Bot ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- Zalo OA ---
ZALO_OA_ID=
ZALO_OA_SECRET=
ZALO_ACCESS_TOKEN=

# --- Web UI Auth ---
WEB_UI_SECRET=changeme-jwt-secret
WEB_UI_ADMIN_PASSWORD=changeme

# ====================================================================
# Optional Integrations
# ====================================================================
# Add as needed when adding new skills/tools
